   816                                      ; DL already contains the column
   817                                  
   818 000005A0 B402                        mov  ah, 0x02
   819 000005A2 30FF                        xor  bh, bh
   820 000005A4 CD10                        int  0x10
   821                                  
   822 000005A6 59                          pop  cx
   823 000005A7 5B                          pop  bx
   824 000005A8 C3                          ret
