  1214 000007E3 CD10                        int  0x10
  1215 000007E5 5B                          pop  bx
  1216 000007E6 58                          pop  ax
  1217 000007E7 C3                          ret
  1218                                  
  1219                                  s2_crlf:
  1220 000007E8 50                          push ax
  1221 000007E9 B00D                        mov  al, 13
  1222 000007EB E8EFFF                      call s2_putc
  1223 000007EE B00A                        mov  al, 10
  1224 000007F0 E8EAFF                      call s2_putc
  1225 000007F3 58                          pop  ax
  1226 000007F4 C3                          ret
  1227                                  
  1228                                  s2_strcmp:
  1229 000007F5 50                          push ax
  1230                                  .loop:
  1231 000007F6 AC                          lodsb
  1232 000007F7 8A25                        mov  ah, [di]
  1233 000007F9 47                          inc  di
  1234 000007FA 38E0                        cmp  al, ah
  1235 000007FC 7506                        jne  .not_equal
  1236 000007FE 84C0                        test al, al
  1237 00000800 7407                        jz   .equal
  1238 00000802 EBF2                        jmp  .loop
  1239                                  .not_equal:
  1240 00000804 58                          pop  ax
  1241 00000805 31C0                        xor  ax, ax
  1242 00000807 40                          inc  ax
  1243 00000808 C3                          ret
  1244                                  .equal:
  1245 00000809 58                          pop  ax
  1246 0000080A 31C0                        xor  ax, ax
  1247 0000080C C3                          ret
