   855 000005C8 C706[A314]0000              mov  word [rl_prev_len], 0
   856 000005CE C706[9F14]FFFF              mov  word [hist_cur], 0xFFFF
   857 000005D4 C60500                      mov  byte [di], 0
   858                                  
   859                                  .loop:
   860 000005D7 30E4                        xor  ah, ah
   861 000005D9 CD16                        int  0x16
   862                                  
   863 000005DB 3C0D                        cmp  al, 13
