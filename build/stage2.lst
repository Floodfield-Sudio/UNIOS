   866 000005E3 7440                        je   .backspace
   867                                  
   868 000005E5 84C0                        test al, al
   869 000005E7 745E                        jz   .special
   870 000005E9 3CE0                        cmp  al, 0xE0
   871 000005EB 745A                        je   .special
   872                                  
   873 000005ED 3B1E[A514]                  cmp  bx, [rl_max]
   874 000005F1 73E4                        jae  .loop
   875                                  
   876 000005F3 E8A201                      call map_scancode
   877                                  
   878 000005F6 39DA                        cmp  dx, bx
   879 000005F8 741A                        je   .append
