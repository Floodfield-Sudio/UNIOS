   648                                  ; =============================================================================
   649                                  ; erase_n_chars; =============================================================================
   650                                  ; erase_n_chars — Erase BX characters from terminal (BS-SP-BS each)
   651                                  ; Preserves all registers.
   652                                  ; =============================================================================
   653                                  erase_n_chars:
   654 000004D8 50                          push ax
   655 000004D9 53                          push bx
   656 000004DA 51                          push cx
   657 000004DB 89D9                        mov  cx, bx
   658 000004DD 30FF                        xor  bh, bh
   659                                  .loop:
   660 000004DF 85C9                        test cx, cx
   661 000004E1 7411                        jz   .done
   662 000004E3 B40E                        mov  ah, 0x0E
   663 000004E5 B008                        mov  al, 8
   664 000004E7 CD10                        int  0x10
   665 000004E9 B020                        mov  al, ' '
   666 000004EB CD10                        int  0x10
   667 000004ED B008                        mov  al, 8
   668 000004EF CD10                        int  0x10
   669 000004F1 49                          dec  cx
   670 000004F2 EBEB                        jmp  .loop
   671                                  .done:
   672 000004F4 59                          pop  cx
   673 000004F5 5B                          pop  bx
   674 000004F6 58                          pop  ax
   675 000004F7 C3                          ret
