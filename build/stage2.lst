   480 000003A9 E81F04                      call s2_puts
   481                                  
   482                                      ; --- Try APM power-off (works on QEMU and real hardware with APM BIOS) ---
   483 000003AC B80153                      mov  ax, 0x5301         ; APM: connect (real-mode interface)
   484 000003AF 31DB                        xor  bx, bx             ; device 0 = APM BIOS
   485 000003B1 CD15                        int  0x15
   486                                  
   487 000003B3 B80853                      mov  ax, 0x5308         ; APM: enable power management for all devices
   488 000003B6 BB0100                      mov  bx, 0x0001
   489 000003B9 B90100                      mov  cx, 0x0001
   490 000003BC CD15                        int  0x15
   491                                  
   492 000003BE B80753                      mov  ax, 0x5307         ; APM: set power state = off
   493 000003C1 BB0100                      mov  bx, 0x0001         ; all devices
   494 000003C4 B90300                      mov  cx, 0x0003         ; state = off
   495 000003C7 CD15                        int  0x15
   496                                  
   497                                      ; --- Try ACPI port write (QEMU PIIX4 / Q35 default shutdown port) -------
   498 000003C9 BA0406                      mov  dx, 0x604          ; QEMU ACPI power-management I/O port
   499 000003CC B80020                      mov  ax, 0x2000         ; PM1_STS SLP_EN=1, SLP_TYP=0 (S5 off)
   500 000003CF EF                          out  dx, ax
   501                                  
   502                                      ; --- Fallback: try legacy power port (VirtualBox / old BIOSes) ----------
   503 000003D0 BA04B0                      mov  dx, 0xB004
   504 000003D3 B80020                      mov  ax, 0x2000
   505 000003D6 EF                          out  dx, ax
   506                                  
   507                                      ; --- Last resort: halt the CPU -------------------------------------------
