     1                                  ; =============================================================================
     2                                  ; UNIOS - STAGE 2 : Diagnostic Shell (Real Mode)                  v0.6
     3                                  ; =============================================================================
     4                                  ; Loaded at 0x9000. Interactive shell.
     5                                  ;
     6                                  ; Commands: help, cpu, mem, arch, disk, clear, reboot, exit,
     7                                  ;           kbd, lg, install
     8                                  ;
     9                                  ; New in v0.4:
    10                                  ;   exit    — ACPI / APM power-off
    11                                  ;   install — Stage 3 install guide
    12                                  ;   lg      — Set language: lg en-us | lg fr-fr
    13                                  ;   kbd     — Toggle QWERTY / AZERTY (saves to INFO_BLOCK)
    14                                  ;   ↑ / ↓   — Command history navigation (10 entries)
    15                                  ;   Persistent settings in INFO_BLOCK+0x10 (lang) / +0x11 (kbd)
    16                                  ;
    17                                  ; Memory layout:
    18                                  ;   0x0500  INFO_BLOCK   (shared with Stage 0/1)
    19                                  ;   0x2000  E820_MAP
    20                                  ;   0x5000  CPU brand string temp buffer
    21                                  ;   0x6000  INPUT_BUF    (current input line, 200 bytes)
    22                                  ;   0x6300  HIST_BUF     (command history, 10 × 80 bytes)
    23                                  ;   0x7C00  [Stack boundary — do not cross]
    24                                  ;   0x9000  Stage 2 code (here)
    25                                  ; =============================================================================
    26                                  
    27                                  [BITS 16]
    28                                  [ORG 0x9000]
    29                                  
    30                                  INFO_BLOCK   equ 0x0500
    31                                  E820_MAP     equ 0x2000
    32                                  INPUT_BUF    equ 0x6000
    33                                  INPUT_MAX    equ 200
    34                                  HIST_BUF     equ 0x6300       ; history ring buffer
    35                                  HIST_MAX     equ 10            ; max history entries
    36                                  HIST_LEN     equ 80            ; max chars per entry (including null)
    37                                  LANG_COUNT   equ 12           ; locale presets
    38                                  KBD_COUNT    equ 12           ; keyboard presets
    39                                  
    40                                  ; =============================================================================
    41                                  ; Entry point
    42                                  ; =============================================================================
    43                                  _start:
    44 00000000 FA                          cli
    45 00000001 31C0                        xor  ax, ax
    46 00000003 8ED8                        mov  ds, ax
    47 00000005 8EC0                        mov  es, ax
    48 00000007 8ED0                        mov  ss, ax
    49 00000009 BC008F                      mov  sp, 0x8F00             ; stack below Stage 2 code
    50 0000000C FB                          sti
    51                                  
    52                                      ; Load persistent settings saved by Stage 1 / previous session
    53 0000000D A01005                      mov  al, [INFO_BLOCK + 0x10]
    54 00000010 A2[9914]                    mov  [lang_id], al         ; locale preset
    55 00000013 A01105                      mov  al, [INFO_BLOCK + 0x11]
    56 00000016 A2[9A14]                    mov  [kbd_layout], al       ; keyboard preset
    57                                  
    58                                      ; Initialise history state
    59 00000019 C706[9B14]0000              mov  word [hist_head],  0
    60 0000001F C706[9D14]0000              mov  word [hist_count], 0
    61 00000025 C706[9F14]FFFF              mov  word [hist_cur],   0xFFFF
    62                                  
    63 0000002B B80300                      mov  ax, 0x0003             ; 80×25 text mode
    64 0000002E CD10                        int  0x10
    65                                  
    66                                      ; Make the hardware cursor visible and stable like a classic CMD prompt.
    67 00000030 B401                        mov  ah, 0x01
    68 00000032 B506                        mov  ch, 0x06
    69 00000034 B107                        mov  cl, 0x07
    70 00000036 CD10                        int  0x10
    71                                  
    72 00000038 BE[8B08]                    mov  si, msg_banner
    73 0000003B E88D07                      call s2_puts
    74 0000003E BE[BD08]                    mov  si, msg_prompt
    75 00000041 E88707                      call s2_puts
    76                                  
