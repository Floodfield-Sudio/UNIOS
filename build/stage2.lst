   883 000005FB 89FD                        mov  bp, di
   884 000005FD 01D5                        add  bp, dx
   885 000005FF 89FE                        mov  si, di
   886 00000601 01DE                        add  si, bx
   887 00000603 89F7                        mov  di, si
   888 00000605 47                          inc  di
   889 00000606 89D8                        mov  ax, bx
   890 00000608 29D0                        sub  ax, dx
   891 0000060A 40                          inc  ax
   892 0000060B 89C1                        mov  cx, ax
   893 0000060D FD                          std
   894 0000060E F3A4                        rep  movsb
   895 00000610 FC                          cld
   896 00000611 5F                          pop  di                 ; restore buffer base
   897 00000612 EB04                        jmp  .store_char
