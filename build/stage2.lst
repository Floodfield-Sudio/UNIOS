  1053                                  
  1054                                  ; =============================================================================
  1055                                  ; s2_line_vram_offset - Compute video memory offset for a line-relative position.
  1056                                  ; Input:  AX = offset from the beginning of the current command line.
  1057                                  ; Output: DI = byte offset in B800:0000 for text mode.
  1058                                  ; Uses:   [rl_start_row], [rl_start_col].
  1059                                  ; =============================================================================
  1060                                  s2_line_vram_offset:
  1061 00000725 53                          push bx
  1062 00000726 51                          push cx
  1063 00000727 52                          push dx
  1064                                  
  1065 00000728 31DB                        xor  bx, bx
  1066 0000072A 8A1E[A214]                  mov  bl, [rl_start_col]
  1067 0000072E 01D8                        add  ax, bx
  1068                                  
  1069 00000730 31D2                        xor  dx, dx
  1070 00000732 BB5000                      mov  bx, 80
  1071 00000735 F7F3                        div  bx                 ; AX = row delta, DX = column
  1072                                  
  1073 00000737 52                          push dx                 ; save column
  1074 00000738 31DB                        xor  bx, bx
  1075 0000073A 8A1E[A114]                  mov  bl, [rl_start_row]
  1076 0000073E 01D8                        add  ax, bx             ; AX = absolute row
  1077                                  
  1078 00000740 BB5000                      mov  bx, 80
  1079 00000743 F7E3                        mul  bx                 ; DX:AX = row * 80
  1080 00000745 59                          pop  cx                 ; CX = column
  1081 00000746 01C8                        add  ax, cx             ; + column
  1082 00000748 D1E0                        shl  ax, 1              ; * 2 bytes per cell
  1083 0000074A 89C7                        mov  di, ax
  1084                                  
  1085 0000074C 5A                          pop  dx
  1086 0000074D 59                          pop  cx
  1087 0000074E 5B                          pop  bx
  1088 0000074F C3                          ret
  1089                                  
  1090                                  ; =============================================================================
  1091                                  ; s2_redraw_line - Redraw the current input buffer and position the cursor.
  1092                                  ; Input: DI = buffer, BX = current length, DX = cursor position.
  1093                                  ; =============================================================================
  1094                                  s2_redraw_line:
  1095 00000750 50                          push ax
  1096 00000751 53                          push bx
  1097 00000752 51                          push cx
  1098 00000753 52                          push dx
  1099 00000754 56                          push si
  1100 00000755 57                          push di
  1101 00000756 06                          push es
  1102                                  
  1103                                      ; Draw directly into text video memory to avoid teletype artifacts.
  1104 00000757 B800B8                      mov  ax, 0xB800
  1105 0000075A 8EC0                        mov  es, ax
  1106 0000075C FC                          cld
  1107                                  
  1108 0000075D 89FE                        mov  si, di
  1109 0000075F 31C0                        xor  ax, ax
  1110 00000761 E8C1FF                      call s2_line_vram_offset    ; DI = video offset for start of line
  1111 00000764 89D9                        mov  cx, bx
  1112                                  
  1113 00000766 B407                        mov  ah, 0x07               ; light grey on black (classic text mode)
  1114                                  .draw_chars:
  1115 00000768 85C9                        test cx, cx
  1116 0000076A 7405                        jz   .clear_tail
  1117 0000076C AC                          lodsb
  1118 0000076D AB                          stosw
  1119 0000076E 49                          dec  cx
  1120 0000076F EBF7                        jmp  .draw_chars
  1121                                  
  1122                                  .clear_tail:
  1123 00000771 A1[A314]                    mov  ax, [rl_prev_len]
  1124 00000774 39D8                        cmp  ax, bx
  1125 00000776 760F                        jbe  .set_cursor
  1126 00000778 29D8                        sub  ax, bx
  1127 0000077A 89C1                        mov  cx, ax
  1128 0000077C B82007                      mov  ax, 0x0720             ; space + attribute
  1129                                  .clear_loop:
  1130 0000077F 85C9                        test cx, cx
  1131 00000781 7404                        jz   .set_cursor
  1132 00000783 AB                          stosw
  1133 00000784 49                          dec  cx
  1134 00000785 EBF8                        jmp  .clear_loop
  1135                                  
  1136                                  .set_cursor:
  1137 00000787 89D0                        mov  ax, dx
  1138 00000789 E8FAFD                      call s2_set_cursor_offset
  1139 0000078C 891E[A314]                  mov  [rl_prev_len], bx
  1140                                  
  1141 00000790 07                          pop  es
  1142 00000791 5F                          pop  di
  1143 00000792 5E                          pop  si
  1144 00000793 5A                          pop  dx
  1145 00000794 59                          pop  cx
  1146 00000795 5B                          pop  bx
  1147 00000796 58                          pop  ax
  1148 00000797 C3                          ret
  1149                                  
  1150                                  ; =============================================================================
  1151                                  ; map_scancode - Convert BIOS ASCII in AL from the active physical layout.
  1152                                  ; kbd_layout selects one entry in kbd_map_table.
  1153                                  ; =============================================================================
  1154                                  map_scancode:
  1155 00000798 53                          push bx
  1156 00000799 56                          push si
  1157 0000079A 57                          push di
  1158                                  
  1159 0000079B 8A1E[9A14]                  mov  bl, [kbd_layout]
  1160 0000079F 80FB0C                      cmp  bl, KBD_COUNT
  1161 000007A2 7202                        jb   .ok
  1162 000007A4 30DB                        xor  bl, bl
  1163                                  .ok:
  1164 000007A6 30FF                        xor  bh, bh
  1165 000007A8 D1E3                        shl  bx, 1
  1166 000007AA 8BBF[FB14]                  mov  di, [kbd_map_table + bx]
  1167 000007AE 81FF[1315]                  cmp  di, qwerty_chars
  1168 000007B2 7413                        je   .done
  1169                                  
  1170 000007B4 BE[1315]                    mov  si, qwerty_chars
  1171                                  .search:
  1172 000007B7 8A1C                        mov  bl, [si]
  1173 000007B9 84DB                        test bl, bl
  1174 000007BB 740A                        jz   .done
  1175 000007BD 38D8                        cmp  al, bl
  1176 000007BF 7404                        je   .mapped
  1177 000007C1 46                          inc  si
  1178 000007C2 47                          inc  di
  1179 000007C3 EBF2                        jmp  .search
  1180                                  
  1181                                  .mapped:
  1182 000007C5 8A05                        mov  al, [di]
  1183                                  
  1184                                  .done:
  1185 000007C7 5F                          pop  di
  1186 000007C8 5E                          pop  si
  1187 000007C9 5B                          pop  bx
  1188 000007CA C3                          ret
  1189                                  
  1190                                  ; =============================================================================
  1191                                  ; Utility functions
  1192                                  ; =============================================================================
  1193                                  s2_puts:
  1194 000007CB 50                          push ax
  1195 000007CC 53                          push bx
  1196                                  .loop:
  1197 000007CD AC                          lodsb
  1198 000007CE 08C0                        or   al, al
  1199 000007D0 7408                        jz   .done
  1200 000007D2 B40E                        mov  ah, 0x0E
  1201 000007D4 31DB                        xor  bx, bx
  1202 000007D6 CD10                        int  0x10
  1203 000007D8 EBF3                        jmp  .loop
  1204                                  .done:
  1205 000007DA 5B                          pop  bx
  1206 000007DB 58                          pop  ax
  1207 000007DC C3                          ret
