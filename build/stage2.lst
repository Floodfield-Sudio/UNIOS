  1024 000006F2 E871FE                      call hist_load_entry
  1025 000006F5 89DA                        mov  dx, bx
  1026 000006F7 E85600                      call s2_redraw_line
  1027 000006FA E9DAFE                      jmp  .loop
  1028                                  
  1029                                  .hist_down_clear:
  1030 000006FD C60500                      mov  byte [di], 0
  1031 00000700 31DB                        xor  bx, bx
  1032 00000702 31D2                        xor  dx, dx
  1033 00000704 C706[9F14]FFFF              mov  word [hist_cur], 0xFFFF
  1034 0000070A E84300                      call s2_redraw_line
  1035 0000070D E9C7FE                      jmp  .loop
  1036                                  
  1037                                  .enter:
  1038 00000710 C60100                      mov  byte [di + bx], 0
  1039 00000713 85DB                        test bx, bx
  1040 00000715 7403                        jz   .skip_save
  1041 00000717 E8DEFD                      call hist_save_current
  1042                                  .skip_save:
