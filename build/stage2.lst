  1249                                  s2_print_dec:
  1250 0000080D 50                          push ax
  1251 0000080E 53                          push bx
  1252 0000080F 51                          push cx
  1253 00000810 52                          push dx
  1254                                  
  1255 00000811 BB0A00                      mov  bx, 10
  1256 00000814 31C9                        xor  cx, cx
  1257                                  
  1258                                  .push_loop:
  1259 00000816 31D2                        xor  dx, dx
  1260 00000818 F7F3                        div  bx
  1261 0000081A 52                          push dx
  1262 0000081B 41                          inc  cx
  1263 0000081C 6685C0                      test eax, eax
  1264 0000081F 75F5                        jnz  .push_loop
  1265                                  
  1266                                  .pop_loop:
