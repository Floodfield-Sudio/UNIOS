   808 00000590 31D2                        xor  dx, dx
   809 00000592 BB5000                      mov  bx, 80
   810 00000595 F7F3                        div  bx                 ; AX = row delta, DX = column
   811                                  
   812 00000597 89C1                        mov  cx, ax             ; CX = row delta
   813 00000599 A0[A114]                    mov  al, [rl_start_row]
