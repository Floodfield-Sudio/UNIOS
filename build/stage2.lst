   795                                  ; =============================================================================
   796                                  ; s2_set_cursor_offset - Position the cursor at prompt-start + AX columns.
   797                                  ; Input:  AX = offset from the beginning of the current command line.
   798                                  ; Uses:   [rl_start_row], [rl_start_col].
   799                                  ; =============================================================================
   800                                  s2_set_cursor_offset:
   801 00000586 53                          push bx
