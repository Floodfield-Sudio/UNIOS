   677                                  ; =============================================================================
   678                                  ; hist_save_current — Save INPUT_BUF into history ring buffer
   679                                  ; Call after a non-empty line is submitted (from inside s2_readline).
   680                                  ; =============================================================================
   681                                  hist_save_current:
   682 000004F8 50                          push ax
   683 000004F9 56                          push si
   684 000004FA 57                          push di
   685 000004FB 51                          push cx
   686                                  
   687                                      ; Destination = HIST_BUF + hist_head * HIST_LEN
   688 000004FC A1[9B14]                    mov  ax, [hist_head]
   689 000004FF B95000                      mov  cx, HIST_LEN
   690 00000502 F7E1                        mul  cx                 ; AX = offset (fits in 16 bits: max 9*80=720)
   691 00000504 050063                      add  ax, HIST_BUF
   692 00000507 89C7                        mov  di, ax
   693                                  
   694                                      ; Copy INPUT_BUF → slot (null-terminated, max HIST_LEN-1)
   695 00000509 BE0060                      mov  si, INPUT_BUF
   696 0000050C B94F00                      mov  cx, HIST_LEN - 1
   697                                  .copy:
   698 0000050F AC                          lodsb
   699 00000510 AA                          stosb
   700 00000511 84C0                        test al, al
   701 00000513 7405                        jz   .done
   702 00000515 E2F8                        loop .copy
   703 00000517 C60500                      mov  byte [di], 0       ; force null termination
   704                                  .done:
   705                                  
   706                                      ; Advance hist_head (ring wrap)
   707 0000051A A1[9B14]                    mov  ax, [hist_head]
   708 0000051D 40                          inc  ax
   709 0000051E 83F80A                      cmp  ax, HIST_MAX
   710 00000521 7202                        jb   .no_wrap
   711 00000523 31C0                        xor  ax, ax
   712                                  .no_wrap:
   713 00000525 A3[9B14]                    mov  [hist_head], ax
   714                                  
   715                                      ; Increment count (cap at HIST_MAX)
   716 00000528 A1[9D14]                    mov  ax, [hist_count]
   717 0000052B 83F80A                      cmp  ax, HIST_MAX
   718 0000052E 7D04                        jge  .skip_inc
   719 00000530 40                          inc  ax
   720 00000531 A3[9D14]                    mov  [hist_count], ax
   721                                  .skip_inc:
   722                                  
   723                                      ; Reset navigation cursor
   724 00000534 C706[9F14]FFFF              mov  word [hist_cur], 0xFFFF
   725                                  
   726 0000053A 59                          pop  cx
   727 0000053B 5F                          pop  di
   728 0000053C 5E                          pop  si
   729 0000053D 58                          pop  ax
   730 0000053E C3                          ret
   731                                  
   732                                  ; =============================================================================
   733                                  ; hist_get_ptr — Return SI pointing to history entry AX (0=newest)
   734                                  ; Uses ring buffer: actual_idx = (hist_head - 1 - AX + 1000) % HIST_MAX
   735                                  ; Clobbers nothing (saves/restores BX, CX, DX).
   736                                  ; =============================================================================
   737                                  hist_get_ptr:
   738 0000053F 50                          push ax
   739 00000540 53                          push bx
   740 00000541 51                          push cx
   741 00000542 52                          push dx
   742                                  
   743 00000543 89C3                        mov  bx, ax             ; BX = relative index
   744 00000545 A1[9B14]                    mov  ax, [hist_head]    ; AX = hist_head (next-write slot)
   745 00000548 48                          dec  ax                 ; -1 → most-recent slot
   746 00000549 29D8                        sub  ax, bx             ; -relative
   747 0000054B 05E803                      add  ax, 1000           ; ensure positive (HIST_MAX*100)
   748 0000054E 31D2                        xor  dx, dx
   749 00000550 B90A00                      mov  cx, HIST_MAX
   750 00000553 F7F1                        div  cx                 ; DX = actual_idx in ring buffer
   751                                  
   752                                      ; SI = HIST_BUF + actual_idx * HIST_LEN
   753 00000555 89D0                        mov  ax, dx
   754 00000557 B95000                      mov  cx, HIST_LEN
   755 0000055A F7E1                        mul  cx                 ; AX = actual_idx * HIST_LEN (≤720, fits in AX)
   756 0000055C 050063                      add  ax, HIST_BUF
   757 0000055F 89C6                        mov  si, ax
   758                                  
   759 00000561 5A                          pop  dx
   760 00000562 59                          pop  cx
   761 00000563 5B                          pop  bx
   762 00000564 58                          pop  ax
   763 00000565 C3                          ret
   764                                  
   765                                  ; =============================================================================
   766                                  ; hist_load_entry - Load history[hist_cur] into buffer at DI, update BX length
   767                                  ; Returns BX = length, buffer is null-terminated.
   768                                  ; =============================================================================
   769                                  hist_load_entry:
   770 00000566 50                          push ax
   771 00000567 56                          push si
   772                                  
   773                                      ; Get pointer to the entry
   774 00000568 A1[9F14]                    mov  ax, [hist_cur]
   775 0000056B E8D1FF                      call hist_get_ptr       ; SI = entry pointer
   776                                  
   777                                      ; Copy to DI buffer, count into BX
   778 0000056E 31DB                        xor  bx, bx
   779                                  .copy:
   780 00000570 AC                          lodsb
   781 00000571 84C0                        test al, al
   782 00000573 740B                        jz   .done
   783 00000575 81FBC700                    cmp  bx, INPUT_MAX - 1
   784 00000579 7305                        jae  .done
   785 0000057B 8801                        mov  [di + bx], al
   786 0000057D 43                          inc  bx
   787 0000057E EBF0                        jmp  .copy
   788                                  .done:
   789 00000580 C60100                      mov  byte [di + bx], 0
   790                                  
   791 00000583 5E                          pop  si
   792 00000584 58                          pop  ax
   793 00000585 C3                          ret
